{
  "name": "zo-market-maker",
  "version": "0.1.0",
  "description": "A simple market maker bot for 01 Exchange (Zo Protocol)",
  "type": "module",
  "main": "dist/cli/bot.js",
  "scripts": {
    "build": "tsc",
    "bot": "node --import tsx src/cli/bot.ts",
    "monitor": "node --import tsx src/cli/monitor.ts",
    "check": "biome check src",
    "format": "biome format --write src",
    "lint": "biome lint src",
    "test": "vitest run --reporter=verbose",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 stop zo-mm",
    "logs:pm2": "pm2 logs zo-mm"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@n1xyz/nord-ts": "^0.3.5",
    "@solana/web3.js": "^1.98.0",
    "blessed": "^0.1.81",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "lodash-es": "^4.17.23",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/blessed": "^0.1.27",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.0",
    "pm2": "^6.0.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
